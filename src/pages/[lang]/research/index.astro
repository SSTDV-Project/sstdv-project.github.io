---
import type { GetStaticPaths } from 'astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, locales, type Locale } from '~/i18n';
import { Icon } from 'astro-icon/components';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };
const metadata = { title: t(lang, 'features.heroTitle') };
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline={t(lang, 'features.heroTagline')}
    title={t(lang, 'features.heroTitle')}
    subtitle={t(lang, 'features.heroSubtitle')}
  />

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 grid grid-cols-1 md:grid-cols-2 gap-6">
    <a href={getRelativeLocaleUrl(lang, '/research/generation/')}
      class="group flex flex-col gap-4 rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:border-blue-400 dark:hover:border-blue-600 transition-all p-8">
      <div class="w-12 h-12 rounded-xl bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center">
        <Icon name="tabler:wand" class="w-6 h-6 text-blue-600 dark:text-blue-400" />
      </div>
      <div>
        <p class="text-xs font-bold tracking-widest uppercase text-blue-500 mb-1">01</p>
        <h2 class="text-2xl font-bold font-heading text-heading group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
          {t(lang, 'features.generationTitle')}
        </h2>
        <p class="mt-2 text-muted text-sm leading-relaxed" set:html={t(lang, 'features.generationSubtitle')} />
      </div>
      <div class="mt-auto flex items-center gap-1 text-sm font-medium text-blue-600 dark:text-blue-400">
        View research <Icon name="tabler:arrow-right" class="w-4 h-4" />
      </div>
    </a>

    <a href={getRelativeLocaleUrl(lang, '/research/evaluation/')}
      class="group flex flex-col gap-4 rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:border-emerald-400 dark:hover:border-emerald-600 transition-all p-8">
      <div class="w-12 h-12 rounded-xl bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center">
        <Icon name="tabler:chart-bar" class="w-6 h-6 text-emerald-600 dark:text-emerald-400" />
      </div>
      <div>
        <p class="text-xs font-bold tracking-widest uppercase text-emerald-500 mb-1">02</p>
        <h2 class="text-2xl font-bold font-heading text-heading group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">
          {t(lang, 'features.evaluationTitle')}
        </h2>
        <p class="mt-2 text-muted text-sm leading-relaxed" set:html={t(lang, 'features.evaluationSubtitle')} />
      </div>
      <div class="mt-auto flex items-center gap-1 text-sm font-medium text-emerald-600 dark:text-emerald-400">
        View research <Icon name="tabler:arrow-right" class="w-4 h-4" />
      </div>
    </a>
  </div>
</Layout>
