---
import type { GetStaticPaths } from 'astro';
import { t, locales, type Locale } from '~/i18n';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };
const metadata = { title: t(lang, 'features.evaluationTitle') };

const quantitativeItems = [
  { index: 1, title: t(lang, 'features.statisticalSimilarityTitle'), desc: t(lang, 'features.statisticalSimilarityDesc') },
  { index: 2, title: t(lang, 'features.objectiveRelevanceTitle'),    desc: t(lang, 'features.objectiveRelevanceDesc') },
];
const qualitativeItems = [
  { index: 1, title: t(lang, 'features.turingTestTitle'), desc: t(lang, 'features.turingTestDesc') },
];
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="Research"
    title={t(lang, 'features.evaluationTitle')}
  />

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8 grid grid-cols-1 md:grid-cols-3 gap-4">
      {[
        {
          label: 'Objective',
          color: 'bg-emerald-600',
          text: 'Establish a rigorous, multi-layered evaluation framework that comprehensively validates the quality and utility of synthetic spatio-temporal data across statistical, task-specific, and perceptual dimensions.',
        },
        {
          label: 'Purpose',
          color: 'bg-emerald-500',
          text: 'Ensure that synthetic data is statistically faithful, preserves downstream task utility, and passes expert human assessment — providing reliable evidence for safe substitution of real patient data.',
        },
        {
          label: 'Methodology',
          color: 'bg-emerald-400',
          text: 'Combine quantitative statistical measures (distributional similarity, multivariate correlation, longitudinal trends) with structured expert Turing tests to validate realism at every level.',
        },
      ].map(({ label, color, text }) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm overflow-hidden">
          <div class={`${color} px-4 py-2`}>
            <span class="text-xs font-bold tracking-widest uppercase text-white">{label}</span>
          </div>
          <p class="px-5 py-4 text-sm text-muted leading-relaxed">{text}</p>
        </div>
      ))}
    </div>

    <!-- Quantitative -->
    <p class="text-xs font-bold tracking-widest uppercase text-muted mb-3">Quantitative Evaluation</p>
    <div class="flex flex-col gap-4 mb-8">
      {quantitativeItems.map(({ index, title, desc }) => (
        <div class="flex gap-5 p-6 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm">
          <div class="flex-shrink-0 pt-1">
            <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400 font-bold text-sm">
              {index}
            </div>
          </div>
          <div class="flex-1">
            <h3 class="text-base font-bold font-heading mb-2" set:html={title} />
            <div class="text-sm text-muted leading-relaxed [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mt-2 [&_ul]:space-y-1 [&_ul_ul]:mt-1 [&_strong]:font-semibold [&_strong]:text-heading [&_a]:text-primary [&_a]:underline [&_img]:rounded-lg [&_img]:mt-4 [&_img]:w-full" set:html={desc} />
          </div>
        </div>
      ))}
    </div>

    <!-- Qualitative -->
    <p class="text-xs font-bold tracking-widest uppercase text-muted mb-3">Qualitative Evaluation</p>
    <div class="flex flex-col gap-4">
      {qualitativeItems.map(({ index, title, desc }) => (
        <div class="flex gap-5 p-6 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm">
          <div class="flex-shrink-0 pt-1">
            <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400 font-bold text-sm">
              {index}
            </div>
          </div>
          <div class="flex-1">
            <h3 class="text-base font-bold font-heading mb-2" set:html={title} />
            <div class="text-sm text-muted leading-relaxed [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mt-2 [&_ul]:space-y-1 [&_ul_ul]:mt-1 [&_strong]:font-semibold [&_strong]:text-heading [&_a]:text-primary [&_a]:underline [&_img]:rounded-lg [&_img]:mt-4 [&_img]:w-full" set:html={desc} />
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
