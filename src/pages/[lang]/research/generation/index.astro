---
import type { GetStaticPaths } from 'astro';
import { t, locales, type Locale } from '~/i18n';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };
const metadata = { title: t(lang, 'features.generationTitle') };

const items = [
  { index: 1, emoji: '🧠', title: t(lang, 'features.knowledgeEncodingTitle'),      desc: t(lang, 'features.knowledgeEncodingDesc') },
  { index: 2, emoji: '🎯', title: t(lang, 'features.objectiveReinforcementTitle'), desc: t(lang, 'features.objectiveReinforcementDesc') },
  { index: 3, emoji: '🌊', title: t(lang, 'features.dataAssimilationTitle'),       desc: t(lang, 'features.dataAssimilationDesc') },
  { index: 4, emoji: '🔗', title: t(lang, 'features.relationModelingTitle'),       desc: t(lang, 'features.relationModelingDesc') },
];
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="Research"
    title={t(lang, 'features.generationTitle')}
  />

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8 grid grid-cols-1 md:grid-cols-3 gap-4">
      {[
        {
          label: 'Objective',
          color: 'bg-blue-600',
          text: 'Develop a principled framework for generating high-quality synthetic spatio-temporal data by explicitly integrating domain knowledge at every stage of the synthesis pipeline.',
        },
        {
          label: 'Purpose',
          color: 'bg-blue-500',
          text: 'Produce synthetic data that is statistically faithful, structurally coherent, and purpose-aligned, across domains ranging from medical imaging to ocean dynamics.',
        },
        {
          label: 'Methodology',
          color: 'bg-blue-400',
          text: 'Encode physical constraints, inter-variable relationships, and task-specific objectives into generative models.',
        },
      ].map(({ label, color, text }) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm overflow-hidden">
          <div class={`${color} px-4 py-2`}>
            <span class="text-xs font-bold tracking-widest uppercase text-white">{label}</span>
          </div>
          <p class="px-5 py-4 text-sm text-muted leading-relaxed">{text}</p>
        </div>
      ))}
    </div>

    <div class="flex flex-col gap-4">
      {items.map(({ index, emoji, title, desc }) => (
        <div class="flex gap-5 p-6 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm">
          <div class="flex-shrink-0 pt-1">
            <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center text-primary font-bold text-sm">
              {index}
            </div>
          </div>
          <div class="flex-1">
            <h3 class="text-base font-bold font-heading mb-2" set:html={title} />
            <div class="text-sm text-muted leading-relaxed [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mt-2 [&_ul]:space-y-1 [&_ul_ul]:mt-1 [&_strong]:font-semibold [&_strong]:text-heading [&_a]:text-primary [&_a]:underline [&_img]:rounded-lg [&_img]:mt-4 [&_img]:w-full" set:html={desc} />
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
