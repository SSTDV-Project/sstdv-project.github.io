---
import type { GetStaticPaths } from 'astro';
import { t, locales, type Locale } from '~/i18n';
import Hero from '~/components/widgets/Hero.astro';
import Steps from '~/components/widgets/Steps.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: t(lang, 'features.heroTitle'),
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline={t(lang, 'features.heroTagline')}
    title={t(lang, 'features.heroTitle')}
    subtitle={t(lang, 'features.heroSubtitle')}
  />

  <div id="generation" class="max-w-5xl mx-auto px-4 sm:px-6 pt-12 pb-2">
    <p class="text-sm font-bold tracking-widest uppercase text-secondary dark:text-blue-200">
      {t(lang, 'features.generationLabel')}
    </p>
    <h2 class="text-3xl font-bold font-heading text-heading mt-1">
      {t(lang, 'features.generationTitle')}
    </h2>
    <p class="mt-2 text-gray-900 dark:text-white text-lg" set:html={t(lang, 'features.generationSubtitle')} />
    <div class="mt-6 p-6 rounded-xl bg-blue-50 dark:bg-slate-800 border border-blue-200 dark:border-blue-900">
      <h3 class="text-xl font-bold font-heading text-heading mb-3">Significance of the Framework</h3>
      <p class="text-muted leading-relaxed">
        This generation framework establishes a multi-layered synthesis pipeline spanning <strong>knowledge encoding</strong> (domain priors and physical constraints), <strong>relation modeling</strong> (spatiotemporal dependencies and teleconnections), <strong>data assimilation</strong> (observation-guided error correction), and <strong>objective synthesis</strong> (goal-oriented generative conditioning).
      </p>
      <p class="text-muted leading-relaxed mt-3">
        By explicitly encoding domain knowledge at each stage, the framework produces synthetic spatio-temporal data that is statistically faithful, physically plausible, and purpose-aligned — enabling high-quality training data generation across diverse domains including ocean dynamics and medical imaging, while overcoming the limitations of data scarcity and privacy constraints.
      </p>
    </div>
  </div>

  <Steps
    items={[
      {
        title: t(lang, 'features.knowledgeEncodingTitle'),
        description: t(lang, 'features.knowledgeEncodingDesc'),
        icon: 'tabler:brain',
      },
      {
        title: t(lang, 'features.relationModelingTitle'),
        description: t(lang, 'features.relationModelingDesc'),
        icon: 'tabler:network',
      },
      {
        title: t(lang, 'features.dataAssimilationTitle'),
        description: t(lang, 'features.dataAssimilationDesc'),
        icon: 'tabler:adjustments',
      },
      {
        title: t(lang, 'features.objectiveReinforcementTitle'),
        description: t(lang, 'features.objectiveReinforcementDesc'),
        icon: 'tabler:target-arrow',
      },
    ]}
  />

  <div class="bg-blue-50 dark:bg-slate-800">
    <div id="evaluation" class="max-w-5xl mx-auto px-4 sm:px-6 pt-12 pb-2">
      <p class="text-sm font-bold tracking-widest uppercase text-secondary dark:text-blue-200">
        {t(lang, 'features.evaluationLabel')}
      </p>
      <h2 class="text-3xl font-bold font-heading text-heading mt-1">
        {t(lang, 'features.evaluationTitle')}
      </h2>
      <p class="mt-2 text-gray-900 dark:text-white text-lg" set:html={t(lang, 'features.evaluationSubtitle')} />
      <div class="mt-6 p-6 rounded-xl bg-white dark:bg-slate-900 shadow-sm">
        <h3 class="text-xl font-bold font-heading text-heading mb-3">Significance of the Framework</h3>
        <p class="text-muted leading-relaxed">
          This comprehensive evaluation framework establishes a robust, four-layered validation network spanning the <strong>micro</strong> (1D distributions), <strong>meso</strong> (multivariate correlations), <strong>macro</strong> (longitudinal time-series trends), and <strong>clinical</strong> (expert Turing test) levels.
        </p>
        <p class="text-muted leading-relaxed mt-3">
          By combining rigorous mathematical proofs with human expert validation, this project demonstrates that the synthesized 3D T1-w brain MRIs maintain exceptional structural, temporal, and perceptual fidelity. Consequently, it proves that these synthetic images are highly reliable, safe, and valuable as training data for advanced downstream AI tasks, seamlessly substituting real patient data while bypassing privacy and scarcity limitations.
        </p>
      </div>
    </div>

    <Steps
      items={[
        {
          title: t(lang, 'features.statisticalSimilarityTitle'),
          description: t(lang, 'features.statisticalSimilarityDesc'),
          icon: 'tabler:chart-bar',
        },
        {
          title: t(lang, 'features.objectiveRelevanceTitle'),
          description: t(lang, 'features.objectiveRelevanceDesc'),
          icon: 'tabler:check',
        },
        {
          title: t(lang, 'features.turingTestTitle'),
          description: t(lang, 'features.turingTestDesc'),
          icon: 'tabler:user-check',
        },
      ]}
    />
  </div>

</Layout>
