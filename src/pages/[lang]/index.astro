---
import type { GetStaticPaths } from 'astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, locales, type Locale } from '~/i18n';
import { externalLinks } from '~/config/externalLinks';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: 'SSTDV — Synthetic Spatio-Temporal Data Vault',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="About"
    image={{
      src: '~/assets/images/SSTDV_main_figure.png',
      alt: 'SSTDV Main Figure',
    }}
  >
    <Fragment slot="title">SSTDV<span class="text-2xl md:text-3xl font-bold font-heading tracking-tighter block mt-1">(Synthetic Spatio-Temporal Data Vault)</span></Fragment>
    <Fragment slot="subtitle">
      SSTDV(Synthetic Spatio-Temporal Data Vault) is a research project for generating and evaluating synthetic data from real-world spatiotemporal data.
    </Fragment>
  </Hero>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="text-3xl lg:text-4xl font-bold font-heading text-center mb-2">Research Goals</h2>
    <p class="text-xl text-muted text-center mb-10">Overview of research and development technologies pursued by the SSTDV project.</p>
    <div class="space-y-6">
      {[
        {
          index: 1,
          title: 'High-Quality Synthetic Spatio-Temporal Data Generation',
          description: `<ul class="list-decimal pl-5 space-y-1">
            <li><strong>Knowledge Encoding:</strong> Computable data structures and generative models that explicitly encode prior knowledge — structure, dynamics, and constraints — of entities in spatio-temporal data.</li>
            <li><strong>Objective-Reinforced Generation:</strong> Learning models for spatio-temporal data augmentation and generation using reward functions aligned with domain data requirements and objectives.</li>
            <li><strong>Data Assimilation:</strong> Improving synthetic accuracy by correcting accumulated errors and missing data during spatio-temporal generation through data perturbation techniques.</li>
            <li><strong>Relationship Modeling:</strong> Modeling correlations, causality, and teleconnections among multivariate spatio-temporal data from prior knowledge and data, enabling generation through learning and inference.</li>
          </ul>`,
        },
        {
          index: 2,
          title: 'Synthetic Data Quality Evaluation',
          description: `<ul class="list-decimal pl-5 space-y-2">
            <li><strong>Statistical similarity evaluation:</strong> Quantitatively assessing distributional similarity between synthetic and real data — including variable distributions and inter-variable correlations within synthetic data.</li>
            <li><strong>Objective relevance evaluation:</strong> Quantitatively comparing performance improvement from using synthetic data on fixed AI models, evaluated using domain-specific metrics aligned with the intended use of the synthetic data.</li>
            <li><strong>Synthetic data Turing test:</strong> Developing and conducting a domain expert evaluation protocol to validate synthetic spatio-temporal data.</li>
          </ul>`,
        },
        {
          index: 3,
          title: 'Validation and Commercialization',
          description: `<p>The synthetic data generation and evaluation technologies developed through this project are validated in the medical domain through scenario-based demonstrations:</p>
          <ul class="list-disc pl-5 space-y-1 mt-2">
            <li><strong>Brain imaging:</strong> Prediction of brain aging and neurodegenerative disease progression.</li>
            <li><strong>Breast cancer surgical simulation:</strong> Prediction of post-surgical outcomes for breast cancer treatment planning.</li>
          </ul>`,
        },
      ].map(({ index, title, description }) => (
        <div class="flex gap-6 p-6 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm">
          <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-full bg-blue-100 text-primary font-bold text-xl">
            {index}
          </div>
          <div>
            <h3 class="text-xl font-semibold font-heading mb-3">{title}</h3>
            <div class="text-muted dark:text-gray-400" set:html={description} />
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-12 pb-2 text-center">
    <h2 class="text-3xl lg:text-4xl font-bold font-heading mb-2">Research Areas</h2>
    <p class="text-xl text-muted">Core technical research areas spanning synthetic data generation and quality evaluation.</p>
  </div>

  <Features3
    tagline="Generation"
    columns={4}
    isBeforeContent={true}
    items={[
      {
        title: 'Knowledge Encoding',
        description: 'Encoding domain prior knowledge — structure, dynamics, and physical constraints — explicitly into generative models.',
        icon: 'tabler:brain',
      },
      {
        title: 'Relation Modeling',
        description: 'Modeling correlations, causality, and teleconnections among multivariate spatio-temporal data.',
        icon: 'tabler:network',
      },
      {
        title: 'Data Assimilation',
        description: 'Combining numerical model outputs and real observations to generate more reliable spatio-temporal data.',
        icon: 'tabler:adjustments',
      },
      {
        title: 'Objective Synthesis',
        description: 'Goal-oriented generative modeling conditioned on clinical objectives rather than statistical learning alone.',
        icon: 'tabler:target-arrow',
      },
    ]}
  />

  <Features3
    tagline="Evaluation"
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Statistical Similarity',
        description: 'Measuring distributional similarity between real and synthetic data via univariate (KS/KL/JS), multivariate correlation, and longitudinal (LMM) analysis.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Objective Relevance',
        description: 'Assessing biological, anatomical, and clinical validity of synthetic data for AI model training through CNN-based structural and disease-related evaluation.',
        icon: 'tabler:checkup-list',
      },
      {
        title: 'Expert Evaluation',
        description: 'Visual Turing Test in which domain experts blindly classify real vs. synthetic medical images to validate perceptual fidelity.',
        icon: 'tabler:eye',
      },
    ]}
  />

  <Features3
    title="Research Team"
    subtitle="Four research institutions collaborating across generation, evaluation, and use case domains."
    columns={2}
    isAfterContent={true}
    items={[
      {
        title: 'KAIST (CGV/CNI)',
        description: '<ul class="list-disc pl-5 space-y-1"><li>Brain MRI-based shape extraction and conditional image generation.</li><li>Evaluation using classification, detection, and prediction performance metrics.</li></ul>',
        image: '/images/kaist_logo.png',
        classes: { icon: 'h-20 w-auto' },
      },
      {
        title: 'Dongguk University',
        description: '<ul class="list-disc pl-5 space-y-1"><li>Evaluation of multivariate distribution similarity and longitudinal brain MRI synthesis.</li></ul>',
        image: '/images/dongguk_logo.png',
        classes: { icon: 'h-24 w-auto' },
      },
      {
        title: 'Beamworks',
        description: '<ul class="list-disc pl-5 space-y-1"><li>Post-surgical breast MRI generation for medical twin-based surgical planning.</li></ul>',
        image: '/images/beamworks_logo.png',
        classes: { icon: 'h-24 w-auto' },
      },
      {
        title: 'KIOST',
        description: '<ul class="list-disc pl-5 space-y-1"><li>Spatiotemporal dependency learning and sea surface temperature forecasting.</li></ul>',
        image: '/images/kiost_logo.png',
        classes: { icon: 'h-32 w-auto' },
      },
    ]}
  />

  <Features2
    tagline="Resources"
    title="Research & Use Cases"
    subtitle={t(lang, 'resources.subtitle')}
    columns={4}
    items={[
      {
        title: 'Research',
        description: t(lang, 'resources.researchDesc'),
        icon: 'tabler:flask',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/features/') },
      },
      {
        title: 'Use Cases',
        description: t(lang, 'resources.useCasesDesc'),
        icon: 'tabler:stethoscope',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/use-cases/') },
      },
      {
        title: 'Publications & Patents',
        description: t(lang, 'resources.publicationsDesc'),
        icon: 'tabler:file-text',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/publications/') },
      },
      {
        title: 'Software',
        description: t(lang, 'resources.docsDesc'),
        icon: 'tabler:book',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/docs/') },
      },
    ]}
  />

  <Stats
    title="Project Outcomes"
    stats={[
      { title: 'Open-source Software', amount: '14' },
      { title: 'Open Datasets', amount: '7' },
      { title: 'Use Cases', amount: '2' },
    ]}
  />

  <Features2
    title="Get In Touch"
    tagline="Contact"
    columns={2}
    items={[
      {
        title: 'Email',
        description: 'Contact us for research inquiries: <a href="mailto:jinahpark@kaist.ac.kr" class="underline text-blue-600 dark:text-blue-400">jinahpark@kaist.ac.kr</a>',
        icon: 'tabler:mail',
      },
      {
        title: 'GitHub',
        description: 'Access open-source software and datasets: <a href="https://github.com/SSTDV-Project/" target="_blank" class="underline text-blue-600 dark:text-blue-400">github.com/SSTDV-Project</a>',
        icon: 'tabler:brand-github',
      },
    ]}
  />

</Layout>
