---
import type { GetStaticPaths } from 'astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, locales, type Locale } from '~/i18n';
import { externalLinks } from '~/config/externalLinks';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: 'SSTDV — Synthetic Spatio-Temporal Data Vault',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="About"
    image={{
      src: '~/assets/images/SSTDV_main_figure.png',
      alt: 'SSTDV Main Figure',
    }}
  >
    <Fragment slot="title">SSTDV<span class="text-2xl md:text-3xl font-bold font-heading tracking-tighter block mt-1">(Synthetic Spatio-Temporal Data Vault)</span></Fragment>
    <Fragment slot="subtitle">
      SSTDV(Synthetic Spatio-Temporal Data Vault) is a research project for generating and evaluating synthetic data from real-world spatiotemporal data.
    </Fragment>
  </Hero>

  <Features2
    title="Research Goals"
    subtitle="Developing high-quality synthetic spatio-temporal data generation and evaluation technologies through domain knowledge-aware source data enhancement, applied and validated in medical imaging and environmental domains."
    columns={3}
    classes={{ headline: { container: 'max-w-none', subtitle: 'text-lg' } }}
    items={[
      {
        title: 'Data Quality Enhancement',
        description: 'Correct inherent errors in source data, resolve inter-modal inconsistencies, and generate continuous high-resolution spatio-temporal data.',
        icon: 'tabler:sparkles',
      },
      {
        title: 'Data Augmentation',
        description: 'Address data imbalance and bias — including anomalies, lesions, and extreme events — through knowledge-based structure and dynamics modeling of spatio-temporal data.',
        icon: 'tabler:chart-dots',
      },
      {
        title: 'Data Inference',
        description: 'Generate data that is difficult to collect in the real world or not collected across time, space, or individuals through multivariate correlation modeling.',
        icon: 'tabler:network',
      },
    ]}
  />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="text-3xl lg:text-4xl font-bold font-heading text-center mb-2">Research Areas</h2>
    <p class="text-lg text-muted text-center mb-10">Research directions for synthetic data generation, quality evaluation, and validation.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        {
          index: 1,
          title: 'Synthetic Data Generation',
          badge: { label: 'Generation', color: 'bg-blue-100 dark:bg-blue-900/40 text-primary' },
          areas: [
            { icon: '🧠', title: 'Knowledge Encoding' },
            { icon: '🎯', title: 'Objective-Reinforced' },
            { icon: '🌊', title: 'Data Assimilation' },
            { icon: '🔗', title: 'Relationship Modeling' },
          ],
          items: [
            { label: 'Knowledge Encoding', desc: 'Encode domain prior knowledge, including structures, dynamics, and physical constraints, into computable representations and generative models.' },
            { label: 'Objective-Reinforced', desc: 'Train generative models guided by domain-specific objectives and reward functions.' },
            { label: 'Data Assimilation', desc: 'Improve spatio-temporal synthesis accuracy by correcting accumulated errors and data gaps through data perturbation techniques.' },
            { label: 'Relationship Modeling', desc: 'Model correlations, causality, and teleconnections among multivariate spatio-temporal variables for learning- and inference-based generation.' },
          ],
        },
        {
          index: 2,
          title: 'Quality Evaluation',
          badge: { label: 'Evaluation', color: 'bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400' },
          areas: [
            { icon: '📊', title: 'Statistical Similarity' },
            { icon: '✅', title: 'Objective Relevance' },
            { icon: '🧑‍⚕️', title: 'Expert Evaluation' },
          ],
          items: [
            { label: 'Statistical Similarity', desc: 'Evaluate distributional similarity and inter-variable correlations between synthetic and real data.' },
            { label: 'Objective Relevance', desc: 'Assess the contribution of synthetic data to downstream AI model performance using fixed models and domain-specific evaluation metrics.' },
            { label: 'Expert Turing Test', desc: 'Develop domain-expert evaluation protocols to validate the realism and utility of synthetic spatio-temporal data.' },
          ],
        },
        {
          index: 3,
          title: 'Validation & Commercialization',
          badge: { label: 'Validation', color: 'bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400' },
          areas: [
            { icon: '🧠', title: 'Virtual Brain' },
            { icon: '🩺', title: 'Breast Cancer Sim.' },
            { icon: '🌐', title: 'Open Release' },
          ],
          items: [
            { label: 'Use Cases', desc: 'Validate synthetic data through applications in brain aging, neurodegenerative disease prediction, and breast cancer post-surgical outcome prediction.' },
            { label: 'Open Release & Services', desc: 'Release synthetic datasets and software, and provide cloud-based digital services for open access and subscription-based commercialization.' },
          ],
        },
      ].map(({ index, title, badge, areas, items }) => (
        <div class="flex flex-col gap-4 p-6 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm">
          <div class="flex items-center gap-3">
            <div class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-blue-100 dark:bg-blue-900/40 text-primary font-bold text-sm">
              {index}
            </div>
            <h3 class="text-base font-semibold font-heading">{title}</h3>
          </div>
          <div class="border-t border-gray-100 dark:border-gray-800 pt-3">
            <ul class="space-y-2">
              {items.map(({ label, desc }, i) => (
                <li class="p-3 rounded-lg border border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-slate-800/50">
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg bg-white dark:bg-slate-800 border border-gray-200 dark:border-gray-700 text-sm font-semibold text-heading mb-2">
                    {areas[i]?.icon} {label}
                  </span>
                  <p class="text-xs text-muted dark:text-gray-400 leading-relaxed" set:html={desc.replace(/•/g, '<span class="text-primary font-bold">•</span>')} />
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="text-center mb-8">
      <h2 class="text-3xl lg:text-4xl font-bold font-heading mb-2">Research Team</h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">Four research institutions collaborating across generation and evaluation.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        {
          name: 'KAIST',
          logo: '/images/kaist_logo.png',
          logoH: 'h-14',
          roles: ['Brain MRI-based shape extraction and conditional image generation', 'Evaluation using classification, detection, and prediction metrics'],
        },
        {
          name: 'Dongguk University',
          logo: '/images/dongguk_logo.png',
          logoH: 'h-16',
          roles: ['Multivariate distribution similarity evaluation', 'Evaluation of longitudinal brain MRI synthesis'],
        },
        {
          name: 'Beamworks',
          logo: '/images/beamworks_logo.png',
          logoH: 'h-16',
          roles: ['Post-surgical breast MRI generation for medical twin-based surgical planning'],
        },
        {
          name: 'KIOST',
          logo: '/images/kiost_logo.png',
          logoH: 'h-20',
          roles: ['Spatiotemporal dependency learning', 'Sea surface temperature forecasting'],
        },
      ].map(({ name, logo, logoH, roles }) => (
        <div class="flex flex-col items-center gap-4 p-6 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm text-center">
          <div class="h-20 flex items-center justify-center">
            <img src={logo} alt={name} class={`${logoH} w-auto object-contain`} />
          </div>
          <div class="border-t border-gray-100 dark:border-gray-800 w-full pt-4">
            <h3 class="text-sm font-bold font-heading mb-2">{name}</h3>
            <ul class="space-y-1.5 text-left">
              {roles.map((role) => (
                <li class="flex gap-1.5 text-xs text-muted leading-relaxed">
                  <span class="mt-1.5 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-primary"></span>
                  <span>{role}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>

  <Features2
    title="Resources"
    subtitle={t(lang, 'resources.subtitle')}
    columns={4}
    classes={{ headline: { container: 'max-w-none', subtitle: 'text-lg' } }}
    items={[
      {
        title: 'Research',
        description: t(lang, 'resources.researchDesc'),
        icon: 'tabler:flask',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/research/') },
      },
      {
        title: 'Use Cases',
        description: t(lang, 'resources.useCasesDesc'),
        icon: 'tabler:stethoscope',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/use-cases/') },
      },
      {
        title: 'Publications & Patents',
        description: t(lang, 'resources.publicationsDesc'),
        icon: 'tabler:file-text',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/publications/') },
      },
      {
        title: 'Software',
        description: t(lang, 'resources.docsDesc'),
        icon: 'tabler:book',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/software/') },
      },
    ]}
  />

  <Stats
    title="Research Outcomes"
    stats={[
      { title: 'Open-source Software', amount: '14' },
      { title: 'Open Datasets', amount: '7' },
      { title: 'Use Cases', amount: '2' },
    ]}
  />

  <Features2
    title="Get In Touch"
    tagline="Contact"
    columns={2}
    items={[
      {
        title: 'Email',
        description: 'Contact us for research inquiries:<br/><a href="mailto:jinahpark@kaist.ac.kr" class="underline text-blue-600 dark:text-blue-400">jinahpark@kaist.ac.kr</a><br/><a href="mailto:khskhs@kaist.ac.kr" class="underline text-blue-600 dark:text-blue-400">khskhs@kaist.ac.kr</a>',
        icon: 'tabler:mail',
      },
      {
        title: 'GitHub',
        description: 'Access open-source software and datasets:<br/><a href="https://github.com/SSTDV-Project/" target="_blank" class="underline text-blue-600 dark:text-blue-400">github.com/SSTDV-Project</a>',
        icon: 'tabler:brand-github',
      },
    ]}
  />

</Layout>
