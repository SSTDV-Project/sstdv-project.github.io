      <!-- DiffAM -->
      <h3>DiffAM: Differentiable Appearance Modeling</h3>
      <p>Framework for learning and generating image appearances in a differentiable manner. Enables embedding extraction, conditional synthesis, and attribute-level editing.</p>
      <table>
        <tbody>
          <tr><td><strong>Repository</strong></td><td><a href="https://github.com/SSTDV-Project/DiffAM" target="_blank" rel="noopener noreferrer">GitHub</a></td></tr>
          <tr><td><strong>License</strong></td><td>MIT</td></tr>
        </tbody>
      </table>

      <h4>Installation</h4>
      <pre><code class="language-bash">pip install diffam</code></pre>

      <h4>Quick Start</h4>
      <pre><code class="language-python">import diffam, torch
model = diffam.DiffAM(pretrained='medical_imaging')
image = torch.randn(1, 1, 256, 256)
embeddings = model.extract_embeddings(image)
synthetic = model.generate(embeddings, n_samples=5)
edited = model.edit_attributes(embeddings, attribute='contrast', strength=1.5)</code></pre>

      <h4>Pretrained Models</h4>
      <table>
        <thead><tr><th>Model</th><th>Best For</th></tr></thead>
        <tbody>
          <tr><td><code>medical_imaging_v1</code></td><td>MRI, CT, X-ray</td></tr>
          <tr><td><code>face_v1</code></td><td>Face images</td></tr>
          <tr><td><code>general_v1</code></td><td>Natural images</td></tr>
        </tbody>
      </table>

      <h4>Dependencies</h4>
      <ul>
        <li><code>torch&gt;=2.0</code>, <code>torchvision&gt;=0.15</code>, <code>einops&gt;=0.6</code></li>
      </ul>

      <h4>Citation</h4>
      <pre><code>@software&#123;diffam,
  title  = &#123;DiffAM: Differentiable Appearance Modeling&#125;,
  author = &#123;SSTDV Project&#125;,
  year   = &#123;2024&#125;,
  url    = &#123;https://github.com/SSTDV-Project/DiffAM&#125;
&#125;</code></pre>

      <hr />

      <!-- VCM -->
      <h3>VCM: Variable Coverage Model</h3>
      <p>Framework for generating synthetic data with controllable coverage guarantees, ensuring generated samples adequately represent target subgroups and distributions.</p>
      <table>
        <tbody>
          <tr><td><strong>Repository</strong></td><td><a href="https://github.com/SSTDV-Project/VCM" target="_blank" rel="noopener noreferrer">GitHub</a></td></tr>
          <tr><td><strong>License</strong></td><td>MIT</td></tr>
        </tbody>
      </table>

      <h4>Installation</h4>
      <pre><code class="language-bash">pip install vcm-model</code></pre>

      <h4>Quick Start</h4>
      <pre><code class="language-python">import vcm
model = vcm.VCM(coverage_target=0.95, min_group_size=50, diversity_weight=0.3)
model.fit(real_data, epochs=100)
synthetic_data = model.generate(n_samples=1000, coverage='guaranteed')
coverage = vcm.metrics.coverage(real_data, synthetic_data)
print(f"Actual coverage: &#123;coverage:.2%&#125;")</code></pre>

      <h4>Coverage Modes</h4>
      <table>
        <thead><tr><th>Mode</th><th>Behavior</th></tr></thead>
        <tbody>
          <tr><td><code>guaranteed</code></td><td>Ensures minimum coverage across all subgroups</td></tr>
          <tr><td><code>balanced</code></td><td>Equal weight to coverage and fidelity</td></tr>
          <tr><td><code>fidelity</code></td><td>Optimizes for sample quality</td></tr>
        </tbody>
      </table>

      <h4>Dependencies</h4>
      <ul>
        <li><code>torch&gt;=2.0</code>, <code>numpy&gt;=1.21</code>, <code>scipy&gt;=1.7</code>, <code>scikit-learn&gt;=1.0</code></li>
      </ul>

      <h4>Citation</h4>
      <pre><code>@software&#123;vcm,
  title  = &#123;VCM: Variable Coverage Model&#125;,
  author = &#123;SSTDV Project&#125;,
  year   = &#123;2024&#125;,
  url    = &#123;https://github.com/SSTDV-Project/VCM&#125;
&#125;</code></pre>

